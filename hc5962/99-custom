sed -i 's_https\?://downloads.openwrt.org_https://mirrors.tuna.tsinghua.edu.cn/openwrt_' /etc/apk/repositories.d/distfeeds.list

uci set system.cfg01e48a.zonename='Asia/Shanghai'
uci set system.cfg01e48a.timezone='CST-8'
uci del system.ntp.server
uci add_list system.ntp.server='ntp.ntsc.ac.cn'
uci add_list system.ntp.server='cn.pool.ntp.org'
uci add_list system.ntp.server='time.windows.com'
uci commit system

uci set network.globals.ula_prefix='fd00::/48'
uci commit network

uci set wireless.@wifi-device[0].disabled='0'
